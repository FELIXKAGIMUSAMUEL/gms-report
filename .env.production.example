# ================================
# GMS Report Portal - Production Environment Variables
# ================================
# 
# IMPORTANT: 
# - Replace all placeholder values with your production credentials
# - Keep this file secure and never commit to version control
# - Generate strong secrets using: openssl rand -base64 32
# ================================

# ================================
# DATABASE CONFIGURATION
# ================================
# PostgreSQL connection string for production
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# 
# For cloud databases (add sslmode=require):
# DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public&sslmode=require"
#
# Connection pooling recommended for production (e.g., PgBouncer)
# Example with pooling: postgresql://user:pass@host:6543/db?schema=public&pgbouncer=true

DATABASE_URL="postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE_NAME?schema=public"

# ================================
# AUTHENTICATION (NextAuth.js)
# ================================
# Generate a strong secret: openssl rand -base64 32
# CRITICAL: Use a unique secret for production, never use the example value

NEXTAUTH_SECRET="REPLACE_WITH_GENERATED_SECRET_FROM_OPENSSL_RAND_BASE64_32"

# Your production domain (no trailing slash)
# Examples:
#   https://gms-report.yourdomain.com
#   https://reports.school.org
NEXTAUTH_URL="https://your-production-domain.com"

# ================================
# PUSH NOTIFICATIONS (Optional)
# ================================
# Generate VAPID keys: npx web-push generate-vapid-keys
# If you don't need push notifications, you can leave these empty

NEXT_PUBLIC_VAPID_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY_HERE"
VAPID_PRIVATE_KEY="YOUR_VAPID_PRIVATE_KEY_HERE"
VAPID_SUBJECT="mailto:admin@your-domain.com"

# ================================
# EMAIL CONFIGURATION (Optional)
# ================================
# SMTP server for sending emails (password resets, notifications)
# Format: smtp://username:password@smtp.provider.com:port
# 
# Examples:
#   Gmail: smtp://your-email@gmail.com:app-password@smtp.gmail.com:587
#   SendGrid: smtp://apikey:YOUR_API_KEY@smtp.sendgrid.net:587
#   AWS SES: smtp://username:password@email-smtp.region.amazonaws.com:587

# EMAIL_SERVER="smtp://username:password@smtp.yourprovider.com:587"
# EMAIL_FROM="noreply@your-domain.com"

# ================================
# OPTIONAL: ANALYTICS & MONITORING
# ================================
# Add analytics/monitoring service keys if needed
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# SENTRY_DSN="https://xxx@sentry.io/xxx"

# ================================
# OPTIONAL: FILE STORAGE
# ================================
# If using cloud storage for uploads (S3, Azure, etc.)
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_REGION="us-east-1"
# S3_BUCKET_NAME="your-bucket-name"

# ================================
# APPLICATION SETTINGS
# ================================
# Node environment (should be 'production' for production deployments)
NODE_ENV="production"

# Logging level (error, warn, info, debug)
# LOG_LEVEL="info"

# ================================
# SECURITY SETTINGS
# ================================
# Enable CORS if your frontend is on a different domain
# CORS_ORIGIN="https://your-frontend-domain.com"

# Rate limiting (requests per minute per IP)
# RATE_LIMIT_MAX="100"

# Session timeout (in seconds, default is 30 days)
# SESSION_MAX_AGE="2592000"

# ================================
# PRODUCTION CHECKLIST
# ================================
# Before deploying, ensure:
# □ DATABASE_URL points to production database with SSL enabled
# □ NEXTAUTH_SECRET is a strong, unique value (32+ characters)
# □ NEXTAUTH_URL matches your production domain exactly
# □ All sensitive credentials are updated (no defaults/examples)
# □ Database backups are configured
# □ SSL certificate is configured for HTTPS
# □ This file is added to .gitignore
# □ Environment variables are set in your hosting platform
# ================================
