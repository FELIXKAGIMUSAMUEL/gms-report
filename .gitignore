# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# Database backups
# database_backup_*.sql
/backups/

# User uploads (generated at runtime, not in source)
# Ignore all uploaded files but keep directory structure with .gitkeep
/public/uploads/**/*
!/public/uploads/.gitkeep
!/public/uploads/attachments/
!/public/uploads/attachments/.gitkeep
!/public/uploads/avatars/
!/public/uploads/avatars/.gitkeep

# GitHub integration config (contains token)
github-config.json

# Misc leftover files
git_push.log
push_result.txt
DEPLOYMENT_SUMMARY.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
