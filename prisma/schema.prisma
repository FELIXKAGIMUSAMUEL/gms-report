generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  password         String
  name             String
  role             UserRole       @default(GM)
  avatarUrl        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  receivedMessages Message[]      @relation("ReceivedMessages")
  sentMessages     Message[]      @relation("SentMessages")
  notifications    Notification[]
  reactions        Reaction[]
  todos            Todo[]
  pushSubscriptions PushSubscription[]
  attachments      Attachment[]
}

model WeeklyReport {
  id                        String          @id @default(cuid())
  weekNumber                Int
  year                      Int
  weekStartDate             DateTime
  weekEndDate               DateTime
  publishedAt               DateTime?
  isDraft                   Boolean         @default(true)
  feesCollectionPercent     Float           @default(0)
  schoolsExpenditurePercent Float           @default(0)
  infrastructurePercent     Float           @default(0)
  totalEnrollment           Int             @default(0)
  theologyEnrollment        Int             @default(0)
  p7PrepExamsPercent        Float           @default(0)
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  admissions                Int             @default(0)
  syllabusCoveragePercent   Float           @default(0)
  term                      Int             @default(1)
  generalManager            String?
  comments                  Comment[]
  reactions                 Reaction[]
  schoolKPIData             SchoolKPIData[]

  @@unique([weekNumber, year, term])
  @@index([year, term, weekNumber])
  @@index([publishedAt])
}

model SchoolKPIData {
  id                      String       @id @default(cuid())
  weeklyReportId          String
  weeklyReport            WeeklyReport @relation(fields: [weeklyReportId], references: [id], onDelete: Cascade)
  school                  String
  year                    Int
  term                    Int
  week                    Int
  feesCollectionPercent   Float        @default(0)
  expenditurePercent      Float        @default(0)
  infrastructurePercent   Float        @default(0)
  syllabusCoveragePercent Float        @default(0)
  admissionsCount         Int          @default(0)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  @@unique([weeklyReportId, school])
  @@index([year, term, week])
  @@index([school])
}

model Reaction {
  id             String        @id @default(cuid())
  type           ReactionType
  comment        String?
  sectionId      String
  weeklyReportId String?
  userId         String
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyReport   WeeklyReport? @relation(fields: [weeklyReportId], references: [id], onDelete: Cascade)

  @@index([weeklyReportId])
  @@index([sectionId])
}

model KPIData {
  id                        String   @id @default(cuid())
  month                     Int
  year                      Int
  feesCollectionPercent     Float    @default(0)
  schoolsExpenditurePercent Float    @default(0)
  infrastructurePercent     Float    @default(0)
  totalEnrollment           Int      @default(0)
  theologyEnrollment        Int      @default(0)
  p7PrepExamsPercent        Float    @default(0)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@unique([month, year])
  @@index([year, month])
}

model Enrollment {
  id        String   @id @default(cuid())
  school    String
  class     String
  term      Int
  year      Int
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([school, class, term, year])
  @@index([school])
  @@index([year, term])
  @@index([school, year, term])
}

model EnrollmentType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  records   DynamicEnrollment[]

  @@index([name])
}

model DynamicEnrollment {
  id               String         @id @default(cuid())
  enrollmentTypeId String
  enrollmentType   EnrollmentType @relation(fields: [enrollmentTypeId], references: [id], onDelete: Cascade)
  school           String         @default("")
  class            String         @default("")
  year             Int
  term             Int
  count            Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([enrollmentTypeId, school, class, year, term])
  @@index([school])
  @@index([year, term])
  @@index([school, year, term])
}

model IncomeSource {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model OtherIncome {
  id         String   @id @default(cuid())
  year       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  source     String
  percentage Float    @default(0)
  month      Int      @default(1)
  amount     Float    @default(0)
  term       Int      @default(1)
  week       Int?

  @@index([year, term, month])
  @@index([year, term, week])
  @@index([source])
}

enum FinancialEntryType {
  INCOME
  EXPENSE
}

model FinancialEntry {
  id        String              @id @default(cuid())
  type      FinancialEntryType
  amount    Float               @default(0)
  year      Int
  term      Int                 @default(1)
  month     Int                 @default(1)
  week      Int?
  school    String?
  source    String?
  category  String?
  notes     String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([year, term, month])
  @@index([type])
  @@index([school])
  @@index([source])
  @@index([category])
}

model BudgetEntry {
  id        String   @id @default(cuid())
  year      Int
  term      Int      @default(1)
  category  String
  amount    Float    @default(0)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, term, category])
  @@index([year, term])
  @@index([category])
}

model P7PrepPerformance {
  id          String   @id @default(cuid())
  year        Int      @unique
  prep1       Float    @default(0)
  prep2       Float    @default(0)
  prep3       Float    @default(0)
  prep4       Float    @default(0)
  prep5       Float    @default(0)
  prep6       Float    @default(0)
  prep7       Float    @default(0)
  prep8       Float    @default(0)
  prep9       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  p6Promotion Float    @default(0)
  ple         Float    @default(0)

  @@index([year])
}

model P7PrepResult {
  id           String   @id @default(cuid())
  school       String
  prepNumber   Int
  term         Int
  year         Int
  enrollment   Int      @default(0)
  agg4         Int      @default(0)  // Students with aggregates 4-12
  divisionI    Int      @default(0)
  divisionII   Int      @default(0)
  divisionIII  Int      @default(0)
  divisionIV   Int      @default(0)
  divisionU    Int      @default(0)  // Ungraded students
  averageScore Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([school, prepNumber, term, year])
  @@index([school])
  @@index([year, term])
  @@index([prepNumber])
  @@index([school, year, term])
}

model P7PleResult {
  id          String   @id @default(cuid())
  school      String
  year        Int
  popn        Int      @default(0)
  agg4        Int      @default(0)
  divisionI   Int      @default(0)
  divisionII  Int      @default(0)
  divisionIII Int      @default(0)
  divisionIV  Int      @default(0)
  divisionU   Int      @default(0)
  api         Float    @default(0)
  rank        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([school, year])
  @@index([school])
  @@index([year])
}

model P6PromotionResult {
  id          String   @id @default(cuid())
  school      String
  year        Int
  setNumber   Int
  popn        Int      @default(0)
  absences    Int      @default(0)
  actualPopn  Int      @default(0)
  agg4        Int      @default(0)
  divisionI   Int      @default(0)
  divisionII  Int      @default(0)
  divisionIII Int      @default(0)
  divisionIV  Int      @default(0)
  ungraded    Int      @default(0)
  api         Float    @default(0)
  rank        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([school, year, setNumber])
  @@index([year])
  @@index([year, setNumber])
  @@index([school, year])
}

model UpcomingEvent {
  id          String       @id @default(cuid())
  date        DateTime
  activity    String
  inCharge    String
  rate        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  status      ItemStatus   @default(ACTIVE)
  attachments Attachment[]

  @@index([date])
  @@index([status])
}

model GMProject {
  id             String       @id @default(cuid())
  projectName    String
  progress       Float        @default(0)
  projectManager String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  status         ItemStatus   @default(ACTIVE)
  attachments    Attachment[]

  @@index([status])
}

model WeeklyScorecard {
  id              String   @id @default(cuid())
  week            Int
  year            Int
  school          String
  academicPercent Float    @default(0)
  financePercent  Float    @default(0)
  qualityPercent  Float    @default(0)
  tdpPercent      Float    @default(0)
  theologyPercent Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  term            Int      @default(1)

  @@unique([week, year, term, school])
  @@index([year, term, week])
}

model RedIssue {
  id          String       @id @default(cuid())
  issue       String
  inCharge    String
  status      IssueStatus  @default(OPEN)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  itemStatus  ItemStatus   @default(ACTIVE)
  attachments Attachment[]

  @@index([itemStatus])
  @@index([status])
}

model School {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model TheologyEnrollment {
  id        String   @id @default(cuid())
  school    String
  year      Int
  term      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  class     String
  count     Int      @default(0)

  @@unique([school, class, term, year])
  @@index([school])
  @@index([year, term])
  @@index([school, year, term])
}

model Message {
  id            String    @id @default(cuid())
  content       String
  senderId      String
  recipientId   String
  isRead        Boolean   @default(false)
  readAt        DateTime?
  attachmentUrl String?   // File attachment URL
  attachmentName String?  // Original filename
  attachmentType String?  // File MIME type
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  recipient     User      @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  sender        User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([recipientId])
  @@index([isRead])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  data      String?
  userId    String
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  auth       String
  p256dh     String
  userAgent  String?
  deviceName String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

model Todo {
  id            String    @id @default(cuid())
  userId        String
  title         String
  description   String?
  dueDate       DateTime
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  isDeferred    Boolean   @default(false)
  deferredUntil DateTime?
  priority      String    @default("MEDIUM")
  category      String    @default("GENERAL")
  reminderSent  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isCompleted])
  @@index([dueDate])
  @@index([isDeferred])
}

model TermSetting {
  id         String   @id @default(cuid())
  term       Int
  year       Int
  startDate  DateTime
  endDate    DateTime
  weeksCount Int      @default(13)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([term, year])
  @@index([year, term])
  @@index([startDate])
}

model OrganizationalGoal {
  id           String   @id @default(cuid())
  title        String
  description  String?
  category     String
  targetValue  Float
  currentValue Float    @default(0)
  unit         String
  year         Int
  term         Int?
  progress     Float    @default(0)
  status       String   @default("in-progress")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([year, term])
  @@index([category])
  @@index([status])
}

model AlertConfig {
  id         String   @id @default(cuid())
  name       String
  type       String
  threshold  Float
  operator   String
  isActive   Boolean  @default(true)
  recipients String   @default("all")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([type])
  @@index([isActive])
}

model AlertHistory {
  id            String    @id @default(cuid())
  configId      String
  school        String?
  metric        String
  expectedValue Float
  actualValue   Float
  severity      String    @default("medium")
  message       String
  isResolved    Boolean   @default(false)
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime  @default(now())

  @@index([configId])
  @@index([school])
  @@index([severity])
  @@index([isResolved])
  @@index([createdAt])
}

model Comment {
  id        String       @id @default(cuid())
  reportId  String
  field     String
  text      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  report    WeeklyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([field])
  @@index([createdAt])
}

model PLEResult {
  id                 String   @id
  school             String
  year               Int
  candidatesEnrolled Int      @default(0)
  divisionI          Int      @default(0)
  divisionII         Int      @default(0)
  divisionIII        Int      @default(0)
  divisionIV         Int      @default(0)
  divisionC5         Int      @default(0)
  divisionC6         Int      @default(0)
  divisionP7         Int      @default(0)
  divisionP8         Int      @default(0)
  divisionU          Int      @default(0)
  englishD1          Int      @default(0)
  englishD2          Int      @default(0)
  englishC3          Int      @default(0)
  englishC4          Int      @default(0)
  englishC5          Int      @default(0)
  englishC6          Int      @default(0)
  englishP7          Int      @default(0)
  englishP8          Int      @default(0)
  englishP9          Int      @default(0)
  mathsD1            Int      @default(0)
  mathsD2            Int      @default(0)
  mathsC3            Int      @default(0)
  mathsC4            Int      @default(0)
  mathsC5            Int      @default(0)
  mathsC6            Int      @default(0)
  mathsP7            Int      @default(0)
  mathsP8            Int      @default(0)
  mathsP9            Int      @default(0)
  scienceD1          Int      @default(0)
  scienceD2          Int      @default(0)
  scienceC3          Int      @default(0)
  scienceC4          Int      @default(0)
  scienceC5          Int      @default(0)
  scienceC6          Int      @default(0)
  scienceP7          Int      @default(0)
  scienceP8          Int      @default(0)
  scienceP9          Int      @default(0)
  sstD1              Int      @default(0)
  sstD2              Int      @default(0)
  sstC3              Int      @default(0)
  sstC4              Int      @default(0)
  sstC5              Int      @default(0)
  sstC6              Int      @default(0)
  sstP7              Int      @default(0)
  sstP8              Int      @default(0)
  sstP9              Int      @default(0)
  agg4               Int      @default(0)
  agg5               Int      @default(0)
  agg6               Int      @default(0)
  agg7               Int      @default(0)
  agg8               Int      @default(0)
  agg9               Int      @default(0)
  agg10              Int      @default(0)
  agg11              Int      @default(0)
  agg12              Int      @default(0)
  agg13              Int      @default(0)
  agg14              Int      @default(0)
  agg15              Int      @default(0)
  agg16              Int      @default(0)
  agg17              Int      @default(0)
  agg18              Int      @default(0)
  agg19              Int      @default(0)
  agg20              Int      @default(0)
  agg21              Int      @default(0)
  agg22              Int      @default(0)
  agg23              Int      @default(0)
  agg24              Int      @default(0)
  agg25              Int      @default(0)
  agg26              Int      @default(0)
  agg27              Int      @default(0)
  agg28              Int      @default(0)
  agg29              Int      @default(0)
  agg30              Int      @default(0)
  agg31              Int      @default(0)
  agg32              Int      @default(0)
  agg33              Int      @default(0)
  agg34              Int      @default(0)
  agg35              Int      @default(0)
  agg36              Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime

  @@unique([school, year])
  @@index([school])
  @@index([school, year])
  @@index([year])
}

model Goal {
  id          String    @id @default(cuid())
  title       String
  description String?
  category    String    @default("enrollment")
  targetValue Float
  currentValue Float   @default(0)
  unit        String
  progress    Float    @default(0)
  year        Int
  term        Int?
  status      String   @default("not-started")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([title, year])
  @@index([year, category])
  @@index([status])
}

model Attachment {
  id           String      @id @default(cuid())
  filename     String      // original file name shown to user
  storedName   String      // name saved on disk
  url          String      // public URL path
  mimeType     String
  size         Int         // bytes
  label        String?     // optional description / caption
  uploadedById String
  uploadedBy   User        @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  projectId    String?
  project      GMProject?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issueId      String?
  issue        RedIssue?   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  eventId      String?
  event        UpcomingEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([projectId])
  @@index([issueId])
  @@index([eventId])
  @@index([uploadedById])
}

enum UserRole {
  GM
  TRUSTEE
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ItemStatus {
  ACTIVE
  COMPLETED
}

enum ReactionType {
  THUMBS_UP
  THUMBS_DOWN
  COMMENT
}

enum NotificationType {
  MESSAGE
  REPORT_PUBLISHED
  REPORT_COMMENT
  REACTION
  SYSTEM
}
