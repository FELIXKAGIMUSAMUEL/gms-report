// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id                      String   @id @default(cuid())
  year                    Int
  quarter                 Int
  baptisms                Int      @default(0)
  professionOfFaith       Int      @default(0)
  tithes                  Float    @default(0)
  combinedOfferings       Float    @default(0)
  membership              Int      @default(0)
  sabbathSchoolAttendance Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([year, quarter])
  @@index([year, quarter])
}
