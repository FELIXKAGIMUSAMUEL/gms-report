# ─────────────────────────────────────────────────────────────────
# GMS Report — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string
# Use connection pooling (pgBouncer) for production
DATABASE_URL="postgresql://username:password@localhost:5432/gms_report?schema=public"

# ── NextAuth ──────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Set to your production domain (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ── Web Push / VAPID Keys ─────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@yourdomain.com"
