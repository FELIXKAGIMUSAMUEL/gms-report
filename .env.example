# Database Configuration
# Use connection pooling for production (e.g., pgBouncer or Supabase pooling)
DATABASE_URL="postgresql://username:password@hostname:5432/database_name?schema=public"

# NextAuth Configuration
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Web Push VAPID Keys
# Generate VAPID keys at: https://vapidkeys.com/ or using web-push library
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-public-vapid-key"
VAPID_PRIVATE_KEY="your-private-vapid-key"
VAPID_SUBJECT="mailto:admin@yourdomain.com"

# Optional: Node Environment
NODE_ENV="production"
